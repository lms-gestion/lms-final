{
  "root": true,
  "extends": ["next/core-web-vitals", "prettier"],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "react-hooks/exhaustive-deps": "warn",
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }],
    "@next/next/no-html-link-for-pages": "off"
  },
  "ignorePatterns": [
    "node_modules",
    ".next",
    ".turbo",
    "dist",
    "build",
    "out",
    "coverage",
    "electron-legacy",
    "*.config.js",
    "*.config.ts"
  ]
}
