{
  "name": "@lms/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "db:generate": "tsx scripts/run-with-env.ts drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:push": "tsx scripts/run-with-env.ts drizzle-kit push",
    "db:studio": "tsx scripts/run-with-env.ts drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.34.1",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.25.0",
    "tsx": "^4.19.1"
  }
}
